    end

    -- Shorthand: Window("TabName") ‚Üí same as Window:CreateTab
    setmetatable(WindowAPI, {
        __call = function(self, cfg)
            if type(cfg) == "string" then cfg = { Name = cfg } end
            return Window:CreateTab(cfg)
        end,
        __index = Window,
    })

    table.insert(self._Windows, WindowAPI)
    return WindowAPI
end

-- ============================================================
--  NOTIFICATION SYSTEM
-- ============================================================
function NexusLib:Notify(cfg)
    cfg = cfg or {}
    local title    = cfg.Title    or cfg.Name or "Notification"
    local text     = cfg.Text     or cfg.Description or ""
    local duration = cfg.Duration or 4
    local ntype    = cfg.Type     or "Info"
    local T        = self._Theme

    local typeColors = {
        Success = T.Success,
        Warning = T.Warning,
        Error   = T.Error,
        Info    = T.Primary,
    }
    local typeIcons = {
        Success = "‚úď",
        Warning = "‚ö†",
        Error   = "‚úē",
        Info    = "‚ĄĻ",
    }

    local color = typeColors[ntype] or T.Primary
    local icon  = typeIcons[ntype]  or "‚ĄĻ"

    self._NotifCount = self._NotifCount + 1

    local notif = Create("Frame", {
        Name            = "Notif_" .. self._NotifCount,
        Size            = UDim2.new(1, 0, 0, 72),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        BackgroundTransparency = 1,
        ZIndex          = 200,
        Parent          = self._NotifContainer,
    })
    RoundCorner(notif, 10)
    Create("UIStroke", { Color = color, Thickness = 1, Transparency = 0.5, Parent = notif })

    -- Accent side bar
    Create("Frame", {
        Size            = UDim2.new(0, 3, 1, -16),
        Position        = UDim2.new(0, 0, 0, 8),
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        ZIndex          = 201,
        Parent          = notif,
    })

    -- Icon circle
    local iconFrame = Create("Frame", {
        Size            = UDim2.new(0, 30, 0, 30),
        Position        = UDim2.new(0, 14, 0.5, -15),
        BackgroundColor3 = color,
        BackgroundTransparency = 0.8,
        BorderSizePixel = 0,
        ZIndex          = 201,
        Parent          = notif,
    })
    RoundCorner(iconFrame, 15)
    Create("TextLabel", {
        Size            = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text            = icon,
        TextColor3      = color,
        Font            = Enum.Font.GothamBold,
        TextSize        = 13,
        ZIndex          = 202,
        Parent          = iconFrame,
    })

    Create("TextLabel", {
        Size            = UDim2.new(1, -60, 0, 20),
        Position        = UDim2.new(0, 52, 0, 14),
        BackgroundTransparency = 1,
        Text            = title,
        TextColor3      = T.Text,
        Font            = Enum.Font.GothamBold,
        TextSize        = 13,
        TextXAlignment  = Enum.TextXAlignment.Left,
        ZIndex          = 201,
        Parent          = notif,
    })

    Create("TextLabel", {
        Size            = UDim2.new(1, -60, 0, 28),
        Position        = UDim2.new(0, 52, 0, 34),
        BackgroundTransparency = 1,
        Text            = text,
        TextColor3      = T.TextDim,
        Font            = Enum.Font.Gotham,
        TextSize        = 11,
        TextXAlignment  = Enum.TextXAlignment.Left,
        TextWrapped     = true,
        ZIndex          = 201,
        Parent          = notif,
    })

    -- Progress bar
    local progressBg = Create("Frame", {
        Size            = UDim2.new(1, -16, 0, 2),
        Position        = UDim2.new(0, 8, 1, -8),
        BackgroundColor3 = T.Border,
        BorderSizePixel = 0,
        ZIndex          = 201,
        Parent          = notif,
    })
    RoundCorner(progressBg, 1)
    local progressFill = Create("Frame", {
        Size            = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        ZIndex          = 202,
        Parent          = progressBg,
    })
    RoundCorner(progressFill, 1)

    -- Slide in
    notif.Position = UDim2.new(1, 20, 0, 0)
    Tween(notif, {
        BackgroundTransparency = 0,
        Position               = UDim2.new(0, 0, 0, 0),
    }, 0.35, Enum.EasingStyle.Back)

    -- Progress countdown
    Tween(progressFill, { Size = UDim2.new(0, 0, 1, 0) }, duration, Enum.EasingStyle.Linear)

    -- Dismiss
    task.delay(duration, function()
        Tween(notif, {
            BackgroundTransparency = 1,
            Position               = UDim2.new(1, 20, 0, 0),
        }, 0.35)
        task.delay(0.4, function()
            notif:Destroy()
        end)
    end)

    -- Click to dismiss early
    local dismissBtn = Create("TextButton", {
        Size            = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text            = "",
        ZIndex          = 203,
        Parent          = notif,
    })
    dismissBtn.MouseButton1Click:Connect(function()
        Tween(notif, { BackgroundTransparency = 1, Position = UDim2.new(1, 20, 0, 0) }, 0.25)
        task.delay(0.3, function() notif:Destroy() end)
    end)
end

-- ============================================================
--  CONFIG SYSTEM
-- ============================================================
function NexusLib:SaveConfig(name)
    SaveConfig(name, self._ConfigData or {})
end

function NexusLib:LoadConfig(name)
    local data = LoadConfig(name)
    self._ConfigData = data
    return data
end

-- ============================================================
--  LIBRARY ENTRY POINT
-- ============================================================
local function Init()
    -- Create instance of NexusLib
    local lib = setmetatable({}, NexusLib)
    lib._Theme      = Themes.Blue
    lib._Lang       = Languages.English
    lib._LangName   = "English"
    lib._Windows    = {}
    lib._NotifCount = 0
    lib._ConfigData = {}

    lib:_Init()

    -- Public API returned to the user
    local API = {}

    -- Library("Title") ‚Üí creates window (shorthand)
    -- Library:Window({...}) ‚Üí creates window (explicit)
    -- Library:SetTheme("Red") ‚Üí change theme
    -- Library:SetLanguage("Arabic") ‚Üí change language
    -- Library:Notify({...}) ‚Üí show notification

    function API:CreateWindow(cfg)
        if type(cfg) == "string" then cfg = { Title = cfg } end
        return lib:CreateWindow(cfg)
    end

    function API:SetTheme(name)  lib:SetTheme(name)    end
    function API:SetLanguage(n)  lib:SetLanguage(n)    end
    function API:Notify(cfg)     lib:Notify(cfg)       end
    function API:SaveConfig(n)   lib:SaveConfig(n)     end
    function API:LoadConfig(n)   return lib:LoadConfig(n) end
    function API:GetTheme()      return lib._Theme     end
    function API:GetLang()       return lib._Lang      end
    function API:GetLangName()   return lib._LangName  end

    -- Language access: API.Lang.Arabic.AutoFarm, API.Lang.English.AutoFarm
    API.Lang = Languages

    -- Shorthand: calling the table directly creates a window
    setmetatable(API, {
        __call = function(self, cfg, ...)
            if type(cfg) == "string" then
                -- Could be theme name
                if Themes[cfg] then
                    lib:SetTheme(cfg)
                    return self
                end
                -- Otherwise create window
                return lib:CreateWindow({ Title = cfg })
            elseif type(cfg) == "table" then
                return lib:CreateWindow(cfg)
            end
        end,
    })

    -- Show language selection on load
    lib:_ShowLanguageSelect(function(langName)
        lib:Notify({
            Title    = langName == "Arabic" and "ŔÖōĪō≠ō®ōßŔč ō®ŔÉ" or "Welcome",
            Text     = langName == "Arabic" and "ō™ŔÖ ō™ō≠ŔÖŔäŔĄ NexusLib ō®ŔÜō¨ōßō≠!" or "NexusLib loaded successfully!",
            Duration = 4,
            Type     = "Success",
        })
    end)

    return API
end

return Init()
