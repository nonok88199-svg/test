    Create("Frame", {
        Size            = UDim2.new(0, 8, 0, 8),
        Position        = UDim2.new(0, 14, 0.5, -4),
        BackgroundColor3 = T.Primary,
        BorderSizePixel = 0,
        ZIndex          = 12,
        Parent          = titleBar,
    })
    -- secondary dot
    Create("Frame", {
        Size            = UDim2.new(0, 5, 0, 5),
        Position        = UDim2.new(0, 25, 0.5, -2),
        BackgroundColor3 = T.PrimaryLight,
        BorderSizePixel = 0,
        ZIndex          = 12,
        Parent          = titleBar,
    })

    Create("TextLabel", {
        Size            = UDim2.new(0, 200, 1, 0),
        Position        = UDim2.new(0, 38, 0, 0),
        BackgroundTransparency = 1,
        Text            = title,
        TextColor3      = T.Text,
        Font            = Enum.Font.GothamBold,
        TextSize        = 15,
        TextXAlignment  = Enum.TextXAlignment.Left,
        ZIndex          = 12,
        Parent          = titleBar,
    })

    Create("TextLabel", {
        Size            = UDim2.new(0, 150, 1, 0),
        Position        = UDim2.new(0, 38, 0, 16),
        BackgroundTransparency = 1,
        Text            = subtitle,
        TextColor3      = T.TextMuted,
        Font            = Enum.Font.Gotham,
        TextSize        = 11,
        TextXAlignment  = Enum.TextXAlignment.Left,
        ZIndex          = 12,
        Parent          = titleBar,
    })

    -- ‚ĒÄ‚ĒÄ Control Buttons ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    local function CtrlBtn(icon, xOffset, color)
        local btn = Create("TextButton", {
            Size            = UDim2.new(0, 28, 0, 28),
            Position        = UDim2.new(1, xOffset, 0.5, -14),
            BackgroundColor3 = T.SurfaceAlt,
            Text            = icon,
            TextColor3      = color or T.TextDim,
            Font            = Enum.Font.GothamBold,
            TextSize        = 13,
            BorderSizePixel = 0,
            ZIndex          = 13,
            Parent          = titleBar,
        })
        RoundCorner(btn, 6)
        btn.MouseEnter:Connect(function()
            Tween(btn, { BackgroundColor3 = color or T.Border }, 0.15)
            Tween(btn, { TextColor3 = T.Text }, 0.15)
        end)
        btn.MouseLeave:Connect(function()
            Tween(btn, { BackgroundColor3 = T.SurfaceAlt }, 0.15)
            Tween(btn, { TextColor3 = color or T.TextDim  }, 0.15)
        end)
        return btn
    end

    local closeBtn    = CtrlBtn("‚úē", -10,  T.Error)
    local minimizeBtn = CtrlBtn("‚ÄĒ", -44,  T.TextDim)

    -- ‚ĒÄ‚ĒÄ Sidebar (tab list) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    local sidebar = Create("Frame", {
        Name            = "Sidebar",
        Size            = UDim2.new(0, 140, 1, -46),
        Position        = UDim2.new(0, 0, 0, 46),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        ZIndex          = 11,
        Parent          = mainFrame,
    })

    -- Sidebar border
    Create("Frame", {
        Size            = UDim2.new(0, 1, 1, 0),
        Position        = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = T.Border,
        BorderSizePixel = 0,
        ZIndex          = 12,
        Parent          = sidebar,
    })

    local tabList = Create("ScrollingFrame", {
        Size            = UDim2.new(1, 0, 1, -10),
        Position        = UDim2.new(0, 0, 0, 10),
        BackgroundTransparency = 1,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = T.Primary,
        BorderSizePixel = 0,
        ZIndex          = 12,
        Parent          = sidebar,
    })
    MakeListLayout(tabList, 4)
    MakePadding(tabList, 4, 4, 8, 8)

    -- ‚ĒÄ‚ĒÄ Content area ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    local contentArea = Create("Frame", {
        Name            = "ContentArea",
        Size            = UDim2.new(1, -140, 1, -46),
        Position        = UDim2.new(0, 140, 0, 46),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        ZIndex          = 11,
        Parent          = mainFrame,
    })

    -- ‚ĒÄ‚ĒÄ Dragging ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    local dragging, dragStart, startPos
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            dragStart = input.Position
            startPos  = mainFrame.Position
        end
    end)
    titleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)

    -- ‚ĒÄ‚ĒÄ Open animation ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    mainFrame.Size            = UDim2.new(0, 0, 0, 0)
    mainFrame.BackgroundTransparency = 1
    Tween(mainFrame, { Size = size, BackgroundTransparency = 0 },
        0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    -- ‚ĒÄ‚ĒÄ Minimize / Close ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    local isMinimized = false
    local originalSize = size

    minimizeBtn.MouseButton1Click:Connect(function()
        Ripple(minimizeBtn, T)
        isMinimized = not isMinimized
        if isMinimized then
            Tween(mainFrame, { Size = UDim2.new(0, size.X.Offset, 0, 46) }, 0.3)
        else
            Tween(mainFrame, { Size = originalSize }, 0.3, Enum.EasingStyle.Back)
        end
    end)

    closeBtn.MouseButton1Click:Connect(function()
        Ripple(closeBtn, T)
        Tween(mainFrame, { Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1 }, 0.3)
        task.delay(0.35, function() mainFrame:Destroy() end)
    end)

    -- ‚ĒÄ‚ĒÄ Tab system ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    local Window  = {}
    local tabs    = {}
    local activeTab = nil

    function Window:CreateTab(tabConfig)
        tabConfig = tabConfig or {}
        local tabName = tabConfig.Name or tabConfig[1] or "Tab"
        local tabIcon = tabConfig.Icon or "‚óą"

        -- Tab button in sidebar
        local tabBtn = Create("TextButton", {
            Name            = "TabBtn_" .. tabName,
            Size            = UDim2.new(1, 0, 0, 34),
            BackgroundColor3 = T.SurfaceAlt,
            Text            = "",
            BorderSizePixel = 0,
            ZIndex          = 13,
            Parent          = tabList,
        })
        RoundCorner(tabBtn, 7)

        local tabIndicator = Create("Frame", {
            Size            = UDim2.new(0, 3, 0.6, 0),
            Position        = UDim2.new(0, 0, 0.2, 0),
            BackgroundColor3 = T.Primary,
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            ZIndex          = 14,
            Parent          = tabBtn,
        })
        RoundCorner(tabIndicator, 3)

        Create("TextLabel", {
            Size            = UDim2.new(0, 22, 1, 0),
            Position        = UDim2.new(0, 10, 0, 0),
            BackgroundTransparency = 1,
            Text            = tabIcon,
            TextColor3      = T.TextDim,
            Font            = Enum.Font.Gotham,
            TextSize        = 14,
            ZIndex          = 14,
            Parent          = tabBtn,
        })

        local tabLabel = Create("TextLabel", {
            Size            = UDim2.new(1, -38, 1, 0),
            Position        = UDim2.new(0, 36, 0, 0),
            BackgroundTransparency = 1,
            Text            = tabName,
            TextColor3      = T.TextDim,
            Font            = Enum.Font.Gotham,
            TextSize        = 13,
            TextXAlignment  = Enum.TextXAlignment.Left,
            ZIndex          = 14,
            Parent          = tabBtn,
        })

        -- Tab content page
        local tabPage = Create("ScrollingFrame", {
            Name            = "TabPage_" .. tabName,
            Size            = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = T.Primary,
            BorderSizePixel = 0,
            Visible         = false,
            ZIndex          = 12,
            Parent          = contentArea,
        })
        MakeListLayout(tabPage, 8)
        MakePadding(tabPage, 10, 10, 12, 12)

        -- Auto-resize canvas
        local layout = tabPage:FindFirstChildWhichIsA("UIListLayout")
        layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            tabPage.CanvasSize = UDim2.new(0, 0, 0,
                layout.AbsoluteContentSize.Y + 20)
        end)

        -- Tab selection
        local function SelectTab()
            if activeTab then
                activeTab.Page.Visible = false
                Tween(activeTab.Btn,       { BackgroundColor3 = T.SurfaceAlt  }, 0.2)
                Tween(activeTab.Label,     { TextColor3 = T.TextDim           }, 0.2)
                Tween(activeTab.Indicator, { BackgroundTransparency = 1       }, 0.2)
            end
            tabPage.Visible = true
            Tween(tabBtn,       { BackgroundColor3 = T.SurfaceAlt }, 0.2)
            Tween(tabBtn, {}, 0) -- force
            -- active highlight
            tabBtn.BackgroundColor3 = Color3.fromRGB(
                T.Primary.R * 255 * 0.15 + T.SurfaceAlt.R * 255 * 0.85,
                T.Primary.G * 255 * 0.15 + T.SurfaceAlt.G * 255 * 0.85,
                T.Primary.B * 255 * 0.15 + T.SurfaceAlt.B * 255 * 0.85
            ) -- blend
            Tween(tabLabel,     { TextColor3 = T.Text                         }, 0.2)
            Tween(tabIndicator, { BackgroundTransparency = 0                  }, 0.2)
            activeTab = { Btn = tabBtn, Page = tabPage, Label = tabLabel, Indicator = tabIndicator }
        end

        tabBtn.MouseButton1Click:Connect(function()
            Ripple(tabBtn, T)
            SelectTab()
        end)
        tabBtn.MouseEnter:Connect(function()
            if activeTab and activeTab.Btn ~= tabBtn then
                Tween(tabBtn, { BackgroundColor3 = T.Border }, 0.15)
            end
        end)
        tabBtn.MouseLeave:Connect(function()
            if activeTab and activeTab.Btn ~= tabBtn then
                Tween(tabBtn, { BackgroundColor3 = T.SurfaceAlt }, 0.15)
            end
        end)

        -- Auto-select first tab
        if #tabs == 0 then
            task.defer(SelectTab)
        end

        -- ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        --  TAB ELEMENTS API
        -- ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        local Tab = {}

        -- ‚ĒÄ‚ĒÄ Section label ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        function Tab:AddSection(name)
            local section = Create("Frame", {
                Size            = UDim2.new(1, 0, 0, 28),
                BackgroundTransparency = 1,
                ZIndex          = 13,
                Parent          = tabPage,
            })
            Create("TextLabel", {
                Size            = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text            = string.upper(name or "SECTION"),
                TextColor3      = T.Primary,
                Font            = Enum.Font.GothamBold,
                TextSize        = 10,
                TextXAlignment  = Enum.TextXAlignment.Left,
                ZIndex          = 14,
                Parent          = section,
            })
            Create("Frame", {
                Size            = UDim2.new(1, 0, 0, 1),
                Position        = UDim2.new(0, 0, 1, -1),
                BackgroundColor3 = T.Border,
                BorderSizePixel = 0,
                ZIndex          = 14,
                Parent          = section,
            })
            return section
        end

        -- ‚ĒÄ‚ĒÄ Button ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        function Tab:AddButton(btnConfig)
            btnConfig = btnConfig or {}
            local name     = btnConfig.Name or "Button"
            local desc     = btnConfig.Description or ""
            local callback = btnConfig.Callback or btnConfig[1] or function() end

            local holder = Create("Frame", {
                Size            = UDim2.new(1, 0, 0, desc ~= "" and 54 or 38),
                BackgroundColor3 = T.SurfaceAlt,
                BorderSizePixel = 0,
                ZIndex          = 13,
                Parent          = tabPage,
            })
            RoundCorner(holder, 8)
            Create("UIStroke", { Color = T.Border, Thickness = 1, Parent = holder })

            Create("TextLabel", {
                Size            = UDim2.new(1, -100, 0, 22),
                Position        = UDim2.new(0, 12, 0, desc ~= "" and 8 or 8),
                BackgroundTransparency = 1,
                Text            = name,
                TextColor3      = T.Text,
                Font            = Enum.Font.GothamSemibold,
                TextSize        = 13,
                TextXAlignment  = Enum.TextXAlignment.Left,
                ZIndex          = 14,
                Parent          = holder,
            })

            if desc ~= "" then
                Create("TextLabel", {
                    Size            = UDim2.new(1, -100, 0, 16),
                    Position        = UDim2.new(0, 12, 0, 30),
                    BackgroundTransparency = 1,
                    Text            = desc,
                    TextColor3      = T.TextMuted,
                    Font            = Enum.Font.Gotham,
                    TextSize        = 11,
                    TextXAlignment  = Enum.TextXAlignment.Left,
                    ZIndex          = 14,
                    Parent          = holder,
