        Position             = UDim2.new(0.5, 0, 0.5, 0),
        BackgroundTransparency = 0,
    }, 0.4, Enum.EasingStyle.Back)

    -- Selection logic
    local function SelectLanguage(name, myFrame, otherFrame)
        selectedLang = name
        Tween(myFrame,    { BackgroundColor3 = T.Primary    }, 0.2)
        Tween(otherFrame, { BackgroundColor3 = T.SurfaceAlt }, 0.2)
    end

    enBtn.MouseButton1Click:Connect(function()
        SelectLanguage("English", enFrame, arFrame)
    end)
    arBtn.MouseButton1Click:Connect(function()
        SelectLanguage("Arabic", arFrame, enFrame)
    end)

    confirmBtn.MouseEnter:Connect(function()
        Tween(confirmBtn, { BackgroundColor3 = T.PrimaryDark }, 0.15)
    end)
    confirmBtn.MouseLeave:Connect(function()
        Tween(confirmBtn, { BackgroundColor3 = T.Primary     }, 0.15)
    end)

    confirmBtn.MouseButton1Click:Connect(function()
        Ripple(confirmBtn, T)
        self:SetLanguage(selectedLang)
        -- Fade out
        Tween(overlay, { BackgroundTransparency = 1 }, 0.3)
        Tween(card,    { BackgroundTransparency = 1, Position = UDim2.new(0.5, 0, 0.45, 0) }, 0.3)
        task.delay(0.35, function()
            overlay:Destroy()
            card:Destroy()
            if callback then callback(selectedLang) end
        end)
    end)
end

