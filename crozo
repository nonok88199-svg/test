function NexusLib:SetTheme(name)
    local t = Themes[name]
    if t then
        self._Theme = t
    elseif type(name) == "table" then
        self._Theme = name
    end
end

function NexusLib:SetLanguage(name)
    local l = Languages[name]
    if l then
        self._Lang     = l
        self._LangName = name
        if name == "Arabic" then
            self:SetTheme("Red")
        elseif name == "English" then
            self:SetTheme("Blue")
        end
    end
end

