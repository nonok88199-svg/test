                ZIndex          = 14,
                Parent          = holder,
            })
            RoundCorner(keyBtn, 6)
            Create("UIStroke", { Color = T.Primary, Thickness = 1, Parent = keyBtn })

            keyBtn.MouseButton1Click:Connect(function()
                listening    = true
                keyBtn.Text  = "..."
                keyBtn.TextColor3 = T.Warning
                Tween(keyBtn, { BackgroundColor3 = T.SurfaceAlt }, 0.1)
            end)

            UserInputService.InputBegan:Connect(function(input, gp)
                if gp then return end
                if listening then
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        currentKey       = input.KeyCode
                        listening        = false
                        keyBtn.Text      = input.KeyCode.Name
                        keyBtn.TextColor3 = T.Primary
                        Tween(keyBtn, { BackgroundColor3 = T.Background }, 0.1)
                        SafeCall(callback, input.KeyCode)
                    end
                else
                    if input.UserInputType == Enum.UserInputType.Keyboard
                    and input.KeyCode == currentKey then
                        SafeCall(callback, currentKey)
                    end
                end
            end)

            local Element = { Value = currentKey }
            function Element:Get() return currentKey end
            return Element
        end

