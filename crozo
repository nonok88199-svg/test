local function Tween(obj, props, duration, style, direction)
    style     = style     or Enum.EasingStyle.Quart
    direction = direction or Enum.EasingDirection.Out
    local info = TweenInfo.new(duration or 0.25, style, direction)
    local t    = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

local function Create(class, props, children)
    local obj = Instance.new(class)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then
            obj[k] = v
        end
    end
    for _, child in ipairs(children or {}) do
        child.Parent = obj
    end
    if props and props.Parent then
        obj.Parent = props.Parent
    end
    return obj
end

local function RoundCorner(parent, radius)
    return Create("UICorner", { CornerRadius = UDim.new(0, radius or 8), Parent = parent })
end

local function MakePadding(parent, t, b, l, r)
    return Create("UIPadding", {
        PaddingTop    = UDim.new(0, t or 8),
        PaddingBottom = UDim.new(0, b or 8),
        PaddingLeft   = UDim.new(0, l or 8),
        PaddingRight  = UDim.new(0, r or 8),
        Parent        = parent,
    })
end

local function MakeListLayout(parent, spacing, direction, halign, valign)
    return Create("UIListLayout", {
        Padding          = UDim.new(0, spacing or 6),
        FillDirection    = direction or Enum.FillDirection.Vertical,
        HorizontalAlignment = halign or Enum.HorizontalAlignment.Left,
        VerticalAlignment   = valign or Enum.VerticalAlignment.Top,
        SortOrder        = Enum.SortOrder.LayoutOrder,
        Parent           = parent,
    })
end

-- Ripple effect on click
local function Ripple(button, theme)
    local ripple = Create("Frame", {
        Size            = UDim2.new(0, 0, 0, 0),
        AnchorPoint     = Vector2.new(0.5, 0.5),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 0.7,
        BorderSizePixel = 0,
        ZIndex          = button.ZIndex + 5,
        Parent          = button,
    })
    RoundCorner(ripple, 100)

    local mp = button.AbsolutePosition
    local ms = button.AbsoluteSize
    local mx = Mouse.X - mp.X
    local my = Mouse.Y - mp.Y
    ripple.Position = UDim2.new(0, mx, 0, my)

    local size = math.max(ms.X, ms.Y) * 2.5
    Tween(ripple, { Size = UDim2.new(0, size, 0, size), BackgroundTransparency = 1 }, 0.5, Enum.EasingStyle.Quart)
    game:GetService("Debris"):AddItem(ripple, 0.55)
end

-- Safe pcall wrapper for executor compatibility
local function SafeCall(fn, ...)
    local ok, err = pcall(fn, ...)
    if not ok then
        warn("[NexusLib] Error: " .. tostring(err))
    end
    return ok, err
end

-- Config storage (uses writefile/readfile if available, else in-memory)
local ConfigCache = {}
local function SaveConfig(name, data)
    ConfigCache[name] = data
    if writefile then
        SafeCall(function()
            writefile("NexusLib_" .. name .. ".json",
                game:GetService("HttpService"):JSONEncode(data))
        end)
    end
end
local function LoadConfig(name)
    if ConfigCache[name] then return ConfigCache[name] end
    if readfile and isfile then
        local path = "NexusLib_" .. name .. ".json"
        if SafeCall(function() return isfile(path) end) then
            local ok, raw = SafeCall(readfile, path)
            if ok and raw then
                local ok2, decoded = SafeCall(function()
                    return game:GetService("HttpService"):JSONDecode(raw)
                end)
                if ok2 then return decoded end
            end
        end
    end
    return {}
end

